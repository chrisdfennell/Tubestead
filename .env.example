# ============================================================================
# Tubestead environment configuration (OVERRIDES ONLY)
# ----------------------------------------------------------------------------
# Tubestead boots with sane defaults and is configured through the first-run
# setup wizard and the in-app admin UI. Everything below is OPTIONAL and only
# acts as an override. You do NOT need any of this to start the app.
#
# Config precedence (highest wins):
#   setup wizard / admin UI (stored in DB)  >  these env vars  >  built-in defaults
#
# Copy to ".env" and uncomment what you need:
#   cp .env.example .env
# ============================================================================

# ---- Networking / reverse proxy --------------------------------------------
# Internal HTTP port the container listens on (TLS is terminated upstream).
# TUBESTEAD_PORT=8080
# Public base URL, used to build absolute links (tus uploads, etc.) when behind
# a reverse proxy. e.g. https://videos.example.com
# TUBESTEAD_PUBLIC_URL=

# ---- Database ---------------------------------------------------------------
# Provider: Sqlite (default) or SqlServer.
# TUBESTEAD_DB_PROVIDER=Sqlite
# SQLite lives on a LOCAL volume (never on an SMB/NFS share).
# TUBESTEAD_DB_CONNECTION=Data Source=/data/tubestead.db
# To use SQL Server instead:
# TUBESTEAD_DB_PROVIDER=SqlServer
# TUBESTEAD_DB_CONNECTION=Server=mssql;Database=Tubestead;User Id=sa;Password=...;TrustServerCertificate=True

# ---- Storage paths ----------------------------------------------------------
# Media root — point this at your NAS share bind mount (e.g. /share/Tubestead).
# TUBESTEAD_MEDIA_PATH=/media
# Application data (db, temp uploads) — keep on LOCAL disk, not the NAS share.
# TUBESTEAD_DATA_PATH=/data

# ---- NAS-friendly permissions (linuxserver.io style) -----------------------
# Make written media files owned by your NAS user/group.
# PUID=1000
# PGID=1000
# UMASK=022

# ---- Secrets ----------------------------------------------------------------
# Optional fixed key for cookie/data-protection persistence across restarts.
# Leave unset to auto-generate (keys are persisted to the data volume).
# TUBESTEAD_DATAPROTECTION_KEY=
